{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "ignoreDeprecations": "5.0",

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@fintrack/components": ["src/components/index.ts"],
      "@fintrack/pages": ["src/pages/index.ts"],
      "@fintrack/store": ["src/store/index.ts"],
      "@fintrack/hooks": ["src/hooks/index.ts"],
      "@fintrack/types": ["src/types/index.ts"],
      "@fintrack/utils": ["src/utils/index.ts"],
      "@fintrack/data": ["src/data/index.ts"],
      "@fintrack/routes": ["src/routes/index.tsx"],
      "@fintrack/constants": ["src/constants/index.ts"],
      "@fintrack/api": ["src/api/index.ts"],
      "@fintrack/assets/*": ["src/assets/*"]
    }
  },
  "include": ["src"]
}
